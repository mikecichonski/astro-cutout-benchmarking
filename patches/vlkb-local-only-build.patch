+else
+DAVIX_INC := /usr/include/davix
+DAVIX_LIB := -ldavix
+DAVIX_SRC :=
+VLKB_WITH_DAVIX := 1
+endif
+
+ifeq ($(NO_CSV),1)
+CSV_LIB :=
+else
+CSV_LIB := -lcsv
+endif
+
 CC=g++
 CFLAGS_DEBUG   = -g -DFDB_DEBUG
 CFLAGS_RELEASE = -O2 
 FLAGS_COMMON   = -fPIC -Wall -Wextra -Wconversion -fno-common -pthread -DVERSIONSTR='"$(VERSION)"' \

-CFLAGS_COMMON   = -c -Wstrict-prototypes $(FLAGS_COMMON)
+CFLAGS_COMMON   = -c -Wstrict-prototypes $(FLAGS_COMMON) -DVLKB_WITH_DAVIX=$(VLKB_WITH_DAVIX)
 CXX_DEBUG_FLAGS   = -g -DVERBOSE_DEBUG -DFDB_DEBUG
 CXX_RELEASE_FLAGS = -O3
 CXX_DEFAULT_FLAGS = -c -std=c++11 $(FLAGS_COMMON)
-LDFLAGS = -Wall -lvlkbcommon -ldavix -lcfitsio -lcsv -last -last_pal -last_cminpack -last_grf_2.0 -last_grf_3.2 -last_grf_5.6 -last_grf3d -last_err -lstdc++ -lm  
+LDFLAGS = -Wall -lvlkbcommon $(DAVIX_LIB) -lcfitsio $(CSV_LIB) -last -last_pal -last_cminpack -last_grf_2.0 -last_grf_3.2 -last_grf_5.6 -last_grf3d -last_err -lstdc++ -lm  
 INC_PARM=$(foreach d, $(INC_DIR), -I$d)
 LIB_PARM=$(foreach d, $(LIB_DIR), -L$d)
 #================================================================================
@@ -36,11 +55,11 @@ EXT_DIR = ext
 SRC_DIR = src
 OBJ_DIR = obj
 BIN_DIR = bin
-INC_PARM += -I$(EXT_DIR)/include -I$(SRC_DIR)
+INC_PARM += -I$(EXT_DIR)/include -I$(SRC_DIR) $(foreach d, $(DAVIX_INC), -I$d)
 LIB_PARM += -L$(EXT_DIR)/lib
 #================================================================================
 EXECUTABLE = $(BIN_DIR)/$(EXEC_NAME)
-CPP_FILES  = $(wildcard $(SRC_DIR)/*.cpp)
+CPP_FILES  = $(filter-out $(DAVIX_SRC),$(wildcard $(SRC_DIR)/*.cpp))
 OBJ_FILES  = $(addprefix $(OBJ_DIR)/,$(notdir $(CPP_FILES:.cpp=.o))) 
 #================================================================================
 NPROCS = $(shell grep -c 'processor' /proc/cpuinfo)
